# ═══════════════════════════════════════════════════════════════════
# .env.example — Copy this to .env and fill in your actual values
# NEVER commit .env to git! It's in .gitignore.
# ═══════════════════════════════════════════════════════════════════

# ── Zerodha Kite Connect ─────────────────────────────────────────
KITE_API_KEY=your_kite_api_key_here
KITE_API_SECRET=your_kite_api_secret_here
# KITE_ACCESS_TOKEN is auto-generated by login.py — leave blank here
KITE_ACCESS_TOKEN=

# ── Zerodha Account (for automated login — optional) ─────────────
ZERODHA_USER_ID=your_zerodha_client_id
ZERODHA_PASSWORD=your_zerodha_password
ZERODHA_TOTP=your_totp_secret_key  # from Zerodha 2FA setup

# ── Anthropic Claude API ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Telegram Bot ─────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
# Get your chat ID by messaging @userinfobot
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Trading Capital & Risk ────────────────────────────────────────
TRADING_CAPITAL=10000        # Start with ₹10,000 — change anytime
MAX_RISK_PER_TRADE=0.02      # 2% of capital per trade
MAX_OPEN_POSITIONS=5         # Max concurrent positions
MAX_CAPITAL_DEPLOY=0.80      # Deploy max 80% of capital
MIN_CONFIDENCE=7.0           # Claude/strategy min confidence (1-10)
MIN_RISK_REWARD=2.0          # Minimum 1:2 risk:reward

# ── Strategies (comma-separated, remove to disable) ──────────────
ACTIVE_STRATEGIES=ema_crossover,rsi_reversal,macd_momentum,breakout,claude_ai

# ── Bulk Scanning (Top 1000 NSE Stocks) ──────────────────────────
# Enable to scan top 1000 NSE stocks instead of default 15-stock watchlist
# Uses 2-stage filtering: Stage 1 pre-filters by price/volume (fast),
# Stage 2 runs full technical analysis on filtered subset
ENABLE_BULK_SCAN=false       # Set to true to enable (or use --bulk flag)
BULK_SCAN_SIZE=1000          # Target universe size (top N NSE stocks)
PREFILTER_MIN_PRICE=50       # Min stock price for Stage 1 filter (₹)
PREFILTER_MAX_PRICE=10000    # Max stock price for Stage 1 filter (₹)
PREFILTER_MIN_VOLUME=50000   # Min daily volume for Stage 1 filter
MAX_STAGE2_STOCKS=200        # Max stocks to pass to Stage 2 (full analysis)
CACHE_DURATION_HOURS=1.0     # Cache filtered universe for N hours

# ── Two-Tier Claude Scanning (Cost Optimization) ──────────────────
# For bulk scans: Run fast technical strategies first, Claude on top picks only
# Reduces Claude API costs from $2-3/scan to $0.20-0.40/scan
ENABLE_TWO_TIER_CLAUDE=true  # Enable two-tier mode (recommended for bulk)
# Technical strategies for Stage 2A (fast, free)
BULK_SCAN_STRATEGIES=ema_crossover,rsi_reversal,macd_momentum,breakout,52w_breakout
MAX_CLAUDE_STOCKS=20         # Top N stocks to send to Claude (Stage 2B)
MIN_CONFIDENCE_FOR_CLAUDE=6.0  # Minimum technical confidence for Claude

# ── Mode ─────────────────────────────────────────────────────────
DRY_RUN=true   # Set to false when ready for live trading!

# ── Dashboard Security ────────────────────────────────────────────────────────
# Generate hash: python -c "import hashlib; print(hashlib.sha256('yourpassword'.encode()).hexdigest())"
DASHBOARD_PASSWORD_HASH=your_sha256_hash_here
SESSION_TIMEOUT_MINUTES=120

# ── Production Risk Overrides ─────────────────────────────────────────────────
MAX_DAILY_LOSS_PCT=0.03
MAX_WEEKLY_LOSS_PCT=0.06
MAX_TOTAL_DRAWDOWN_PCT=0.15
MAX_SINGLE_STOCK_PCT=0.20
MAX_CONSECUTIVE_LOSSES=4
MIN_WIN_RATE_THRESHOLD=0.35
ATR_SL_MULTIPLIER=2.0
ATR_TARGET_MULTIPLIER=4.0
SLIPPAGE_PCT=0.002

# ── Backtesting ───────────────────────────────────────────────────────────────
BACKTEST_MIN_WIN_RATE=45.0
BACKTEST_MIN_PROFIT_FACTOR=1.2

# ── Advanced Exit Controls (v3) ───────────────────────────────────────────────
MAX_HOLD_DAYS=15              # Force-exit after 15 days
SIDEWAYS_DAYS=8               # Check for sideways after 8 days
SIDEWAYS_PCT=0.005            # 0.5% move = sideways

# ── Partial Profit Booking ────────────────────────────────────────────────────
ENABLE_PARTIAL_EXIT=true      # Book 50% at T1, trail 50% to T2
PARTIAL_BOOK_PCT=0.50         # Sell 50% at first target
PARTIAL_TARGET_MULT=1.5       # T2 = T1 + 1.5x original risk

# ── VIX Filter ────────────────────────────────────────────────────────────────
VIX_REDUCE_THRESHOLD=20.0     # Reduce size above this VIX
VIX_HALT_THRESHOLD=30.0       # No new entries above this VIX

# ── Trade Direction Filter ────────────────────────────────────────
# Set which signals to trade: BUY, SELL, or BOTH  
TRADE_DIRECTION=BUY  # Default: BUY only (recommended for delivery trading)
